  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const timestamp = new Date().toISOString();",
          "const suffix = Date.now().toString().slice(-6);",
          "const taxIdLast4 = String(1000 + (Number(suffix) % 9000));",
          "pm.collectionVariables.set('requestTimestamp', timestamp);",
          "pm.collectionVariables.set('dynamicEmail', `postman.demo.${suffix}@northstarbank.example`);",
          "pm.collectionVariables.set('dynamicTaxIdLast4', taxIdLast4);",
          "console.log(`[Northstar Bank] ${pm.info.requestName} -> ${pm.request.method} ${pm.request.url.toString()}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Contract - response body should be valid JSON', function () {",
          "  pm.expect(function () { pm.response.json(); }).to.not.throw();",
          "});",
          "",
          "pm.test('Contract - response should include a correlation ID', function () {",
          "  const body = pm.response.json();",
          "  const correlationId = body.meta && body.meta.correlationId ? body.meta.correlationId : (body.error && body.error.correlationId ? body.error.correlationId : body.correlationId);",
          "  pm.expect(correlationId).to.be.a('string');",
          "  pm.expect(correlationId).to.match(/^corr_demo_/);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "E2E Workflow",
      "item": [
        {
          "name": "POST /applications - should create a new application and return 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('POST /applications - should create a new application and return 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Contract - created application response should include data and meta', function () {",
                  "  pm.expect(body).to.have.keys(['data', 'meta']);",
                  "  ['id', 'status', 'productType', 'initialDepositAmount', 'riskScore', 'requiredDocuments', 'customer', 'consent', 'decisionSummary', 'createdAt', 'updatedAt'].forEach((field) => pm.expect(body.data).to.have.property(field));",
                  "});",
                  "pm.test('Types - created application should expose expected field types', function () {",
                  "  pm.expect(body.data.id).to.be.a('string');",
                  "  pm.expect(body.data.riskScore).to.be.a('number');",
                  "  pm.expect(body.data.requiredDocuments).to.be.an('array');",
                  "  pm.expect(body.meta.timestamp).to.be.a('string');",
                  "});",
                  "pm.test('Business - new application should start in submitted status', function () {",
                  "  pm.expect(body.data.status).to.eql('submitted');",
                  "  pm.expect(body.data.requiredDocuments).to.include('government-id');",
                  "});",
                  "pm.collectionVariables.set('e2eApplicationId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-correlation-id",
                "value": "corr_demo_postman_e2e_create"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productType\": \"checking\",\n  \"initialDepositAmount\": 250,\n  \"customer\": {\n    \"firstName\": \"Riley\",\n    \"lastName\": \"Morgan\",\n    \"dateOfBirth\": \"1989-04-18\",\n    \"email\": \"{{dynamicEmail}}\",\n    \"phone\": \"+1-555-0172\",\n    \"taxIdLast4\": \"{{dynamicTaxIdLast4}}\",\n    \"address\": {\n      \"line1\": \"410 Market Street\",\n      \"line2\": \"Suite 8\",\n      \"city\": \"Denver\",\n      \"state\": \"CO\",\n      \"postalCode\": \"80202\",\n      \"country\": \"US\"\n    }\n  },\n  \"consent\": {\n    \"acceptedTerms\": true,\n    \"marketingOptIn\": false\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ]
            },
            "description": "Creates a new customer enrollment application for the E2E workflow."
          }
        },
        {
          "name": "GET /applications/:id - should retrieve the created application",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const expectedId = pm.collectionVariables.get('e2eApplicationId');",
                  "pm.test('GET /applications/:id - should retrieve the created application', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Contract - detail response should include application data and meta', function () {",
                  "  pm.expect(body).to.have.keys(['data', 'meta']);",
                  "  pm.expect(body.data).to.include.keys(['id', 'status', 'productType', 'customer', 'createdAt', 'updatedAt']);",
                  "});",
                  "pm.test('Business - returned application should match the captured E2E ID', function () {",
                  "  pm.expect(body.data.id).to.eql(expectedId);",
                  "  pm.expect(body.data.status).to.eql('submitted');",
                  "});"
                ]
              }
            }
